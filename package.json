{
  "name": "librix-monorepo",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev:frontend": "cd frontend && pnpm dev",
    "dev:backend": "cd backend && .venv\\Scripts\\uvicorn app.main:app --reload",
    "dev:all": "concurrently \"pnpm dev:frontend\" \"pnpm dev:backend\"",
    "build:frontend": "cd frontend && pnpm build",
    "typecheck": "cd frontend && pnpm typecheck",
    "install:frontend": "cd frontend && pnpm install",
    "install:backend": "cd backend && pip install -r requirements.txt"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
